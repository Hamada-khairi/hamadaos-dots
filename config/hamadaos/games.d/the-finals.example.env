# The Finals (UE5, DX12, server-heavy) — copy to 2073850.env to activate.
# Tested direction for ≤4GB VRAM laptops:

# Kernel-native Windows sync — better frame pacing in CPU-bound team fights
PROTON_USE_NTSYNC=1

# UE5 streams shaders aggressively; keep the VKD3D cache warm and persistent
VKD3D_SHADER_CACHE_PATH=${XDG_CACHE_HOME:-$HOME/.cache}/hamadaos-shaders

# If you see VRAM-pressure hitching even with low textures, uncomment:
# DXVK_FRAME_RATE=60
