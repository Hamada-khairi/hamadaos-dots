${confDir}/hypr/hyprbars-colors.conf|
# Auto-generated by HyDE Wallbash — hyprbars recolored from the wallpaper.
# Sourced after plugins.conf, so these override the Catppuccin defaults.
plugin {
    hyprbars {
        bar_color = rgba(<wallbash_pry1>cc)
        bar_text_color = rgba(<wallbash_txt1>ff)
    }
}
